{
  "name": "@atcute/atproto",
  "version": "3.1.12",
  "description": "AT Protocol (com.atproto.*) schema definitions",
  "keywords": [
    "atcute",
    "atproto"
  ],
  "license": "0BSD",
  "repository": {
    "url": "https://github.com/mary-ext/atcute",
    "directory": "packages/definitions/atproto"
  },
  "files": [
    "dist/",
    "lib/",
    "!lib/**/*.bench.ts",
    "!lib/**/*.test.ts",
    "!dist/**/*.{test,bench}.*"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./types/*": "./dist/lexicons/types/com/atproto/*.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@atcute/lexicons": "^1.3.1"
  },
  "devDependencies": {
    "@atcute/atproto": "file:",
    "@atcute/lex-cli": "^2.8.1"
  },
  "peerDependencies": {
    "@atcute/lexicons": "^1.0.0"
  },
  "atcute:lexicons": {
    "mappings": {
      "com.atproto.*": {
        "type": "namespace",
        "path": "./types/{{nsid_remainder}}"
      }
    }
  },
  "scripts": {
    "build": "tsgo",
    "pull": "lex-cli pull",
    "generate": "lex-cli generate",
    "prepublish": "rm -rf dist; pnpm run build"
  }
}