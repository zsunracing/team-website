{
  "name": "@atcute/client",
  "version": "4.2.2",
  "description": "lightweight and cute API client for AT Protocol",
  "license": "0BSD",
  "repository": {
    "url": "https://github.com/mary-ext/atcute",
    "directory": "packages/clients/client"
  },
  "files": [
    "dist/",
    "lib/",
    "!lib/**/*.bench.ts",
    "!lib/**/*.test.ts",
    "!dist/**/*.{test,bench}.*"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@atcute/identity": "^1.1.5",
    "@atcute/lexicons": "^1.3.1"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.5",
    "vitest": "^4.1.5",
    "@atcute/atproto": "^3.1.12",
    "@atcute/internal-dev-env": "^1.0.2",
    "@atcute/bluesky": "^3.3.4"
  },
  "peerDependencies": {
    "@atcute/lexicons": "^1.0.0"
  },
  "scripts": {
    "build": "tsgo",
    "postbuild": "node ./scripts/ensure-files.js",
    "test": "vitest run --coverage",
    "prepublish": "rm -rf dist; pnpm run build"
  }
}