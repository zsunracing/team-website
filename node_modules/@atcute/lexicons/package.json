{
  "name": "@atcute/lexicons",
  "version": "1.3.1",
  "description": "AT Protocol core lexicon types and schema validations",
  "license": "0BSD",
  "repository": {
    "url": "https://github.com/mary-ext/atcute",
    "directory": "packages/lexicons/lexicons"
  },
  "files": [
    "dist/",
    "lib/",
    "!lib/**/*.bench.ts",
    "!lib/**/*.test.ts",
